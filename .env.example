# =========================
# TEMPLATE — copie para .env.local e preencha as chaves reais
# Este arquivo É versionado no Git (sem chaves reais)
# =========================

# Grok API (prioridade 1) — https://console.x.ai/
GROK_API_KEY=

# Groq API (prioridade 2) — https://console.groq.com
GROQ_API_KEY=

# OpenRouter API (prioridade 3) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini API (fallback final) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =========================
# CONFIGURAÇÕES DO APP
# =========================

NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =========================
# INDEXAÇÃO — ping-indexing.js
# =========================

# IndexNow (Bing, Yandex, DuckDuckGo) — https://www.indexnow.org
INDEXNOW_KEY=

# Google Indexing API — Service Account em base64
# Como gerar:
#   1. Crie uma Service Account no Google Cloud Console
#   2. Ative a API "Indexing API"
#   3. Baixe o JSON da service account
#   4. Encode: base64 -w 0 service-account.json
#   5. Cole o resultado abaixo (sem quebras de linha)
GOOGLE_SERVICE_ACCOUNT_B64=

# Alternativa: path para o arquivo JSON da service account (desenvolvimento local)
# GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# =========================
# E-MAIL — Resend (envio do resultado do /simulado)
# =========================
# Usado por lib/email-service.js para enviar de verdade o e-mail com o
# resultado do simulado (antes, era só um link mailto: que não enviava nada
# do servidor). Crie sua conta gratuita em https://resend.com (100
# e-mails/dia, 3.000/mês no plano free) e gere a chave em
# https://resend.com/api-keys
RESEND_API_KEY=

# Remetente que aparece nos e-mails enviados. Sem domínio verificado no
# Resend, pode deixar em branco temporariamente — o código usa
# "onboarding@resend.dev" como padrão, mas ele só entrega para o e-mail
# da SUA conta Resend (bom só para testar). Para enviar a qualquer
# destinatário em produção, verifique seu domínio em
# https://resend.com/domains e troque para algo como:
# RESEND_FROM_EMAIL="Passeja Concursos <resultado@passejaconcursos.com.br>"
RESEND_FROM_EMAIL=

# =========================
# ADMIN
# =========================
# Senha para acessar /admin — troque por algo seguro!
ADMIN_PASSWORD=mude_esta_senha_aqui

# =========================
# PAINEL ADMIN — Regenerar / Remover posts em produção
# =========================
# O botão "Regenerar" e a remoção de duplicatas no /admin rodam dentro de uma
# function serverless da Vercel, que tem filesystem somente leitura. Por isso
# essas ações commitam direto no GitHub (em vez de escrever em disco), e a
# Vercel rebuilda a partir do novo commit — igual ao que o GitHub Action de
# geração automática já faz.

# Personal Access Token do GitHub com permissão "Contents: Read and write"
# no repositório (fine-grained token, ou classic token com escopo "repo").
# Gere em: https://github.com/settings/tokens
GITHUB_TOKEN=

# Repositório no formato "usuario/repositorio"
GITHUB_REPO=

# Branch a commitar (geralmente "main")
GITHUB_BRANCH=main

# Mesma URL de Deploy Hook usada pelo GitHub Action (Settings → Git → Deploy
# Hooks na Vercel). Opcional: sem ela, o push no Git já dispara o build padrão,
# só demora um pouco mais para o webhook do Git acionar a Vercel.
VERCEL_DEPLOY_HOOK=

# =========================
# NEWSLETTER — avisos diários de posts novos
# =========================
# Usa o recurso de "Contacts" do próprio Resend para guardar a lista de
# inscritos — não precisa de banco de dados separado nem de criar uma
# Audience com ID próprio (desde a "New Contacts Experience" do Resend,
# os contatos são globais na conta, identificados só pelo e-mail).

# Segredo compartilhado com o GitHub Action (.github/workflows/send-newsletter.yml)
# que dispara o envio diário. Gere algo aleatório, ex: openssl rand -hex 32
NEWSLETTER_CRON_SECRET=

