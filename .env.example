# =========================
# TEMPLATE — copie para .env.local e preencha as chaves reais
# Este arquivo É versionado no Git (sem chaves reais)
# =========================

# Groq API (prioridade 1) — https://console.groq.com
GROQ_API_KEY=

# OpenRouter API (prioridade 2) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini API (fallback final) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =========================
# CONFIGURAÇÕES DO APP
# =========================

NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =========================
# INDEXAÇÃO — ping-indexing.js
# =========================

# IndexNow (Bing, Yandex, DuckDuckGo) — https://www.indexnow.org
INDEXNOW_KEY=

# Google Indexing API — Service Account em base64
# Como gerar:
#   1. Crie uma Service Account no Google Cloud Console
#   2. Ative a API "Indexing API"
#   3. Baixe o JSON da service account
#   4. Encode: base64 -w 0 service-account.json
#   5. Cole o resultado abaixo (sem quebras de linha)
GOOGLE_SERVICE_ACCOUNT_B64=

# Alternativa: path para o arquivo JSON da service account (desenvolvimento local)
# GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# =========================
# ADMIN
# =========================
# Senha para acessar /admin — troque por algo seguro!
ADMIN_PASSWORD=mude_esta_senha_aqui
